{
    "functions": {
        "api_*.php": {
            "runtime": "vercel-php@0.7.0"
        }
    },
    "routes": [
        {
            "src": "/(api_.*\\.php)",
            "dest": "/$1"
        },
        {
            "src": "/login.html",
            "dest": "/login.html"
        },
        {
            "src": "/index.html",
            "dest": "/index.html"
        }
    ]
}